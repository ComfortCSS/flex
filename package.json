{
    "name": "@comfortcss/flex",
    "version": "0.1.0",
    "description": "Modern atomic CSS for Flexbox. Implemented using logical properties, zero-specificity selectors, and a clean architecture. Part of the ComfortCSS ecosystem.",
    "main": "dist/flex.min.css",
    "style": "dist/flex.min.css",
    "files": [
        "dist",
        "src"
    ],
    "repository": {
        "type": "git",
        "url": "git+https://github.com/ComfortCSS/flex.git"
    },
    "scripts": {
        "build": "npx lightningcss --minify --bundle src/index.css -o dist/flex.min.css",
        "prepare": "npm run build",
        "prepublishOnly": "npm run build"
    },
    "keywords": [
        "css",
        "flexbox",
        "modern",
        "layout",
        "accessible",
        "lightweight"
    ],
    "author": "ComfortCSS",
    "license": "MIT",
    "peerDependencies": {
        "@comfortcss/tokens": "^1.0.0"
    },
    "devDependencies": {
        "lightningcss": "^1.32.0",
        "lightningcss-cli": "^1.32.0",
        "@comfortcss/reset": "1.0.1"
    },
    "publishConfig": {
        "access": "public"
    },
    "exports": {
        ".": {
            "style": "./dist/flex.min.css",
            "default": "./dist/flex.min.css"
        },
        "./flex": {
            "style": "./dist/flex.min.css",
            "default": "./dist/flex.min.css"
        },
        "./modules/*": "./src/core/*",
        "./package.json": "./package.json"
    }
}
